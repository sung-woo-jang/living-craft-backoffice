# ==============================================
# Living Craft Backoffice - Environment Variables
# ==============================================
# 로컬 개발 시 .env.local에서 이 파일을 기반으로 값을 설정하세요

# ==============================================
# API 설정
# ==============================================
# Backend API 서버 주소 (로컬: http://localhost:8000, 프로덕션: https://api.example.com)
VITE_API_URL=http://localhost:8000

# API 버전 (선택사항)
VITE_API_VERSION=v1

# ==============================================
# 환경 설정
# ==============================================
# 환경 (development | production)
VITE_ENV=development

# ==============================================
# 애플리케이션 설정
# ==============================================
# 애플리케이션 이름
VITE_APP_NAME=Living Craft 관리자

# 애플리케이션 설명
VITE_APP_DESCRIPTION=인테리어 필름 시공 및 유리 청소 예약 관리 시스템

# ==============================================
# 빌드 설정
# ==============================================
# 빌드 시 소스맵 생성 여부 (개발: true, 프로덕션: false)
VITE_SOURCEMAP=true

# ==============================================
# 기능 플래그
# ==============================================
# 디버그 모드 (개발: true, 프로덕션: false)
VITE_DEBUG=true

# 개발자 도구 표시 여부
VITE_SHOW_DEV_TOOLS=true

# ==============================================
# 타임존
# ==============================================
VITE_TIMEZONE=Asia/Seoul

# ==============================================
# 외부 서비스 (선택사항)
# ==============================================
# Google Analytics ID
# VITE_GA_ID=

# Sentry DSN (에러 트래킹)
# VITE_SENTRY_DSN=
